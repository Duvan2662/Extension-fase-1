{
  "manifest_version": 3,
  "name": "CapturePro — Screenshot to Excel",
  "version": "1.0.0",
  "description": "Captura screenshots de video/canvas y exporta a Excel organizado en filas",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.js"],
      "css": ["src/content/overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "action": {
    "default_title": "CapturePro",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/content/*", "src/assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
